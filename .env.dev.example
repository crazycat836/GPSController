# Copy to `.env.dev` to apply locally. start.py loads `.env.dev` on
# launch; real exported env vars take precedence over values here.

# Disable backend session-token auth so the Vite dev server on :5173
# (no Electron preload to inject the token) can reach the API. Leave
# OFF on shared machines — any local browser tab can hit the API.
GPSCONTROLLER_DEV_NOAUTH=1
